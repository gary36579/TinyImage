# TinyImage 配置
# 三層優先：CLI > .env > 程式碼預設值
# 取消註解即可自訂，未設定時使用右方預設值

# TINYIMAGE_ARC_EXTS=.zip,.7z                 # 預設：.zip,.7z
# TINYIMAGE_IMG_EXTS=.jpg,.jpeg,.png,.webp    # 預設：.jpg,.jpeg,.png,.webp
# TINYIMAGE_INPUT=input                       # 預設：input
# TINYIMAGE_JPEG_PROGRESSIVE=true             # 預設：true
# TINYIMAGE_JPG_TO_WEBP=false                 # 預設：false
# TINYIMAGE_OUTPUT=output                     # 預設：output
# TINYIMAGE_OVERRIDE=false                    # 預設：false
# TINYIMAGE_PNG_LEVEL=9                       # 預設：9
# TINYIMAGE_PNG_LEVEL_STREAM=3                # 預設：3
# TINYIMAGE_PNG_TO_WEBP=false                 # 預設：false
# TINYIMAGE_QUALITY=80                        # 預設：80
# TINYIMAGE_SUFFIX=[minify]                   # 預設：[minify]
# TINYIMAGE_WEBP_METHOD=6                     # 預設：6
# TINYIMAGE_WEBP_METHOD_STREAM=4              # 預設：4
# TINYIMAGE_WATCH_INTERVAL=3                  # 預設：3（秒，監聽模式輪詢間隔）
# TINYIMAGE_WORKERS=                          # 預設：CPU 核心數
